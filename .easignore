# Ignore node modules and local build artifacts
node_modules/
dist/
build/
web-build/
.expo/
.expo-shared/

# Ignore sensitive files and keys
.env
.env.*
.env.*.local
*.pem
*.key
*.p12
*.p8
*.mobileprovision
*.jks
google-play-key.json
google-services.json
GoogleService-Info.plist

# Ignore native IDE configurations and local cache
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# NOTE: We DO NOT ignore android/ and ios/ directories here by default as this is a bare (or prebuilt) workflow.
# EAS Build uses these directories to compile your actual apps.
# If you strictly want EAS to run prebuild from scratch, you can ignore these, but be sure you don't have custom native code inside them.
