rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can read/write their own data
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Courses collection - anyone authenticated can read, only instructors can write
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Instructors collection - anyone authenticated can read
    match /instructors/{instructorId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == instructorId;
    }
    
    // Attendance, tickets, messages - authenticated users only
    match /attendance/{document} {
      allow read, write: if request.auth != null;
    }
    
    match /tickets/{document} {
      allow read, write: if request.auth != null;
    }
    
    match /messages/{document} {
      allow read, write: if request.auth != null;
    }
    
    // Instructor requests - users can create and read their own requests
    match /instructorRequests/{requestId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false; // Only admins should be able to update/delete
    }
    
    // Other collections - authenticated users can read/write
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
